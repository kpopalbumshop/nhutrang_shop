.title-video{display:flex;justify-content:space-between;align-items:center}.title-video .title{font-size:24px;color:var(--sub-color);font-family:"Montserrat-Alternates-Bold";padding:65px 0px 60px;position:relative}@media screen and (max-width: 480px){.title-video .title{padding:30px 0px 50px}}.title-video .title:after{content:' ';width:60px;height:2px;background:var(--main-color);bottom:35px;left:0px;position:absolute}.title-video a{font-family:"Montserrat-Alternates";font-size:16px;color:var(--sub-color)}.videos_block_body{width:calc(100% + 20px);margin:0px -10px;padding-bottom:60px}@media screen and (max-width: 990px){.videos_block_body{display:flex;flex-wrap:wrap}}@media screen and (max-width: 540px){.videos_block_body{padding-bottom:20px}}.list_video_below{margin-top:15px;margin-left:-2px;margin-right:-2px}.list_video_below .video_item{width:100%;float:left;padding:0px;box-sizing:border-box}.videos_block_body .video_item{float:left;box-sizing:border-box;cursor:pointer;margin:0px 15px 15px;width:calc(25% - 30px)}.videos_block_body .video_item:nth-child(1){width:calc(75% - 30px)}.videos_block_body .video_item:nth-child(1) img{height:100%}.video_item_inner_has_img:hover .button-play svg{fill:red}.video_item_inner iframe{height:auto}@media screen and (max-width: 990px){.video_item_inner iframe{height:245px}}@media screen and (max-width: 736px){.video_item_inner iframe{height:371px}}@media screen and (max-width: 540px){.video_item_inner iframe{height:200px}}.videos_block_body .video_item:nth-child(1) iframe{height:490px;width:100%}@media screen and (max-width: 990px){.videos_block_body .video_item:nth-child(1) iframe{height:245px}}@media screen and (max-width: 736px){.videos_block_body .video_item:nth-child(1) iframe{height:371px}}@media screen and (max-width: 540px){.videos_block_body .video_item:nth-child(1) iframe{height:200px}}.video_item_inner_has_img{position:relative;overflow:hidden}@media all and (max-width: 600px){.video_item_inner_has_img{max-height:200px}}.video_item_inner_has_img .button-play{position:absolute;top:calc(50% - 25px);left:calc(50% - 25px)}.video_item_inner_has_img .button-play:hover svg{fill:red}.video_item_inner_has_img .button-play svg{width:50px;height:50px;fill:white}.video_item_inner_has_img .button-play svg:hover{fill:red}.video_item_inner_has_img::after{content:"";display:block;height:50px;left:42%;left:calc(50%-25px);left:-webkit-calc(50%-25px);position:absolute;top:34%;top:calc(50%-25px);top:-webkit-calc(50%-25px);width:50px;background-position:-141px -113px;background-repeat:no-repeat}.video_item:hover .video_item_inner_has_img::after{background-position:-199px -113px}.video-name{position:absolute;bottom:0;width:100%;background:rgba(41,33,36,0.5)}.video-name-inner{padding:10px 10px;color:#FFF}.video_item img{-webkit-transition:all .3s ease-out;-moz-transition:all .3s ease-out;-o-transition:all .3s ease-out;transition:all .3s ease-out;width:100%;height:auto}.video_item:hover img{moz-transform:scale(1.05);-webkit-transform:scale(1.05);-o-transform:scale(1.05);-ms-transform:scale(1.05);transform:scale(1.05)}.video_item:hover .video-name-inner{padding-top:12px;padding-bottom:12px;-webkit-transition:0.35s ease-in-out all;transition:0.35s ease-in-out all}@media screen and (max-width: 990px){.videos_block_body .video_item{float:left;box-sizing:border-box;cursor:pointer;margin:0px 15px 15px;width:calc(100%/2 - 30px)}.videos_block_body .video_item:nth-child(1){width:calc(100%/2 - 30px)}.videos_block_body .video_item:nth-child(1) img{height:100%}}@media only screen and (max-width: 736px){.videos_block_body .video_item{float:none;margin:0px 15px 15px;width:calc(100% - 30px);text-align:center}.videos_block_body .video_item:nth-child(1){width:calc(100% - 30px)}}
