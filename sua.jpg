.form-column-by-fast-block{display:flex;align-items:flex-start;justify-content:space-between;background-color:#EFF0F4}.form-column-by-fast-block .label_error{margin-bottom:10px}.form-column-by-fast-block .left-content{width:45%;float:left}.form-column-by-fast-block .left-content img{width:100%;height:auto;object-fit:cover;vertical-align:middle;display:grid}.form-column-by-fast-block .form_fast_ct{width:calc(100% - 45% - 100px);float:right;padding-bottom:40px}.form-column-by-fast-block .form_fast_ct .block_title{margin-top:100px}@media screen and (max-width: 450px){.form-column-by-fast-block .form_fast_ct .block_title{margin-top:70px}}.form-column-by-fast-block .form_fast_ct .buy_fast_body{margin-top:70px}@media screen and (max-width: 990px){.form-column-by-fast-block .form_fast_ct .buy_fast_body{padding:0px 15px;margin-bottom:20px}}@media screen and (max-width: 450px){.form-column-by-fast-block .form_fast_ct .buy_fast_body{margin-top:20px}}.form-column-by-fast-block .input-text,.form-column-by-fast-block textarea{width:100%;background:#fff;padding:4px 20px;height:50px;border:none;box-sizing:border-box;margin-bottom:10px;border:1px solid #fff;box-sizing:border-box}@media screen and (max-width: 540px){.form-column-by-fast-block .input-text,.form-column-by-fast-block textarea{height:40px}}.form-column-by-fast-block .input-text:focus,.form-column-by-fast-block textarea:focus{border:1px solid #fce0b7c7;box-shadow:rgba(0,0,0,0.1) 0px 10px 15px -3px,rgba(0,0,0,0.05) 0px 4px 6px -2px}.form-column-by-fast-block textarea{padding:10px 20px;height:80px;margin-bottom:20px}.form-column-by-fast-block .ip-50{margin:0px -5px 10px}.form-column-by-fast-block .ip-50 .input-text{width:calc(50% - 10px);margin:0px 5px}.form-column-by-fast-block .ip-50 .input-text:nth-child(1){float:left}.form-column-by-fast-block .ip-50 .input-text:nth-child(2){float:right}.form-column-by-fast-block .button-buy-fast{background:var(--main-color);border:none;color:#fff;padding:10px 0px 10px;width:100%;curso