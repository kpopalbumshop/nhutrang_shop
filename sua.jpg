er span{font-size:14px}}@media screen and (max-width: 450px){.block_testimonials .summary-customer .name-customer span{font-size:12px}}.block_testimonials .summary-customer span{font-weight:bold}.block_testimonials .play-video svg{width:55px;height:55px;position:absolute;top:50%;left:50%;fill:white;transform:translate(-50%, -50%);transition:0.5s;-moz-transition:0.5s;-webkit-transition:0.5s;opacity:0.9;cursor:pointer;opacity:75%}@media screen and (max-width: 450px){.block_testimonials .play-video svg{width:40px;height:40px}}.block_testimonials .play-video svg:hover{fill:red}.block_testimonials .img_video:hover{cursor:pointer}.block_testimonials .img_video:hover svg{fill:red}.block_testimonials .avatar-home{width:55px;margin-top:20px;border-radius:50%;position:relative;margin-left:30px}@media screen and (max-width: 1366px){.block_testimonials .avatar-home{width:50px;margin-top:20px}}@media screen and (max-width: 540px){.block_testimonials .avatar-home{margin-left:5px}}@media screen and (max-width: 450px){.block_testimonials .avatar-home{margin-left:5px;width:40px}}.block_testimonials .avatar-home img{border-radius:50%}.block_testimonials .description-customer{padding:5px 30px 0px 50px;position:relative;white-space:normal;display:-webkit-box;-webkit-line-clamp:3;-webkit-box-orient:vertical;overflow:hidden;box-sizing:border-box;color:#848181;line-height:20px;font-size:13px;font-family:"Montserrat-Alternates"}@media screen and (max-width: 540px){.block_testimonials .description-customer{padding:5px 10px 0px 40px !important}}.block_testimonials .description-customer:before{content:',,';color:var(--extra-color);font-size:60px;position:absolute;top:20px;left:15px;font-weight:bold;transform:rotate(180deg);letter-spacing:-3px;font-style:normal;font-family:sans-serif}@media screen and (max-width: 990px){.block_testimonials .description-customer:before{font-size:80px;top:35px}}@media screen and (max-width: 540px){.block_testimonials .description-customer:before{font-size:50px;t