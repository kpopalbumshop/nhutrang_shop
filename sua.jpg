.product_grid{display:flex;flex-wrap:wrap;margin:0px}.product_grid .item{float:left;box-sizing:border-box;position:relative;text-align:center;width:25%;padding:20px;margin-bottom:18px}.product_grid .item:hover{box-shadow:#64646f33 0px 7px 29px 0px;-webkit-transition:all 0.3s ease-out}.product_grid .item:hover .arraw_right{opacity:1}@media screen and (max-width: 800px){.product_grid .item{width:calc(100% / 3 - 10px)}}@media screen and (max-width: 500px){.product_grid .item{width:calc(100% / 2 - 10px);padding:20px}}.product_grid .product_image{position:relative;text-align:center;margin:-10px}.product_grid .product_image img{width:100%;height:auto}.product_grid .arraw_right{position:absolute;bottom:10px;right:10px;opacity:0}.product_grid .arraw_right span{display:inline-block;background:var(--sub-color);border-radius:50%;width:30px;height:30px;text-align:center;padding-top:4px;box-sizing:border-box}.product_grid .arraw_right span svg{fill:#fff;width:22px;height:22px}.is_new,.is_promotion{border-radius:50%;text-align:center;text-transform:uppercase;display:inline-block;color:#fff;box-sizing:border-box;position:absolute;left:10px;top:10px;background:#fead00;font-size:11px;width:38px;height:38px;padding-top:10px;z-index:1}@media screen and (max-width: 500px){.is_new,.is_promotion{font-size:10px;width:32px;height:32px;padding-top:8px}}.is_promotion{background:var(--sub-color);left:48px}@media screen and (max-width: 500px){.is_promotion{left:42px}}.is_promotion_l0{left:10px !important}@media screen and (max-width: 500px){.is_promotion_l0{left:42px}}.frame_inner>h2,.frame_inner>h3,.frame_inner>.div_name{margin-top:20px;overflow:hidden;height:30px;font-size:18px;text-transform:uppercase;-webkit-line-clamp:1;-webkit-box-orient:vertical;display:-webkit-box;overflow:hidden;font-family:Montserrat-Regular,Helvetica,Arial,'DejaVu Sans','Liberation Sans',Freesans,sans-serif}@media screen and (max-width: 600px){.frame_inner>h2,.frame_inner>h3,.frame_inner>.div_name{font-size:16px}}@media screen and (max-width: 380px){.frame_inner>h2,.frame_inner>h3,.frame_inner>.div_name{font-size:14px}}.frame_inner>h2 a:hover{color:var(--extra-color)}.frame_inner>h3 a:hover{color:var(--extra-color)}.product_grid .name{line-height:20px;font-weight:normal;font-weight:bold;-webkit-line-clamp:1;-webkit-box-orient:vertical;display:-webkit-box;overflow:hidden}.price .price_current{font-size:16px}.price .price_current span{font-weight:bold}@media screen and (max-width: 600px){.price .price_current{font-size:14px}}.price_arae .price_current{font-size:16px;text-align:left;text-align:center}.price_arae .price_current span{font-weight:bold}.price_arae .price_old{text-decoration:line-through;color:#888888;font-size:14px;font-weight:normal;text-align:left;margin-top:2px;font-family:'LexendLight'}.price_arae .price_old span{text-decoration:line-through}
/*# sourceMappingURL=products.css.map */
#headermenu {
  padding-right: 15px; }
  #headermenu .nav-header .level0 {
    float: left;
    padding: 0px 0px 0px 10px;
    position: relative; }
    @media screen and (max-width: 736px) {
      #headermenu .nav-header .level0 {
        padding: 0px 0px 0px 20px; } }
  #headermenu .nav-header .level0:nth-child(1) {
    padding-right: 10px; }
    #headermenu .nav-header .level0:nth-child(1):before {
      display: block;
      width: 15px;
      height: 15px;
      content: "|";
      color: white;
      background-repeat: no-repeat;
      position: absolute;
      left: 100%; }
  #headermenu .nav-header .level0 > a {
    color: white;
    font-family: "Montserrat-Alternates";
    font-size: 13px;
    transition: 1s; }
    #headermenu .nav-header .level0 > a:hover {
      color: var(--sub-color);
      font-weight: bold; }

/*# sourceMappingURL=headermenu.css.map */
@media only screen and (min-width: 1025px){#cssmenu .navigation_main_wrapper{min-height:46px}}#main_menu{transition:all 0.5s cubic-bezier(0.55, 0, 0.1, 1);width:100%;z-index:100}.fixed{position:fixed;z-index:1000;top:0px;width:100%}.slide-down{-ms-transform:translateY(-100%);transform:translateY(-100%)}.slide-up{-ms-transform:translateY(0);transform:translateY(0);padding:6px 0px 4px;border-bottom:1px solid #dddddd8f}.m-slide-down{-ms-transform:translateY(-100%);transform:translateY(-100%)}.m-slide-up{-ms-transform:translateY(0);transform:translateY(0)}#cssmenu .nav .activated a{color:var(--main-color) !important;font-weight:550 !important}#cssmenu .nav{display:flex;justify-content:space-between}#cssmenu .nav>li{float:left;transition:0.3s;position:relative;border:1px solid transparent;border-radius:50px}#cssmenu .nav>li:hover a{color:var(--main-color);font-weight:bold}a.link-home{padding-top:14px !important;padding-bottom:0px !important}#cssmenu .nav .level0 img{position:absolute;left:0px;top:15px}#cssmenu .nav .level0 svg{width:10px;height:10px;fill:var(--main-color);position:absolute;top:52%;transform:translateY(-50%);right:-15px;cursor:pointer}@media screen and (max-width: 1100px){#cssmenu .nav .level0 svg{right:5px}}#cssmenu .nav .level1 a{line-height:30px;display:block;font-size:15px;padding-top:6px;border-radius:5px}#cssmenu .nav .active a{background:var(--main-color);color:#fff !important}#cssmenu .nav .level0>a{padding:0px;color:var(--sub-color);font-weight:bold;font-family:"Montserrat-Alternates";font-size:16px;line-height:60px}@media screen and (max-width: 1100px){#cssmenu .nav .level0>a{padding:1px 20px 0px 20px;font-size:15px}}#cssmenu .nav .level0>span{padding:0px;color:var(--sub-color);font-weight:bold;font-family:"Montserrat-Alternates";font-size:16px;line-height:60px}@media screen and (max-width: 1150px){#cssmenu .nav .level0>span{font-size:14px}}#cssmenu .nav .sub-menu{display:none;position:absolute;top:45px;left:0%;width:300px;z-index:9999;background-color:white;box-shadow:rgba(100,100,111,0.2) 0px 7px 29px 0px}.sub-menu li{width:100%;background:#ffffff;border-bottom:0.2px solid #8c8c8c4f;line-height:34px}.sub-menu a:hover a{color:#fff !important}.sub-menu a{padding:5px 15px 5px 15px;line-height:14px;color:#000}.sub-menu a:hover{background:var(--main-color);color:#fff !important}#cssmenu .nav li:hover>.sub-menu{display:block}#cssmenu .nav>li>.sub-menu .level1:nth-child(1){margin-top:2px !important}.slide-up #cssmenu .nav>li>.sub-menu .level1:nth-child(1){margin-top:38px !important}#cssmenu{position:relative}#cssmenu #menu-button{margin:0;padding:0;border:0;list-style:none;line-height:1;display:none;position:relative;-webkit-box-sizing:border-box;-moz-box-sizing:border-box;box-sizing:border-box}#cssmenu>ul.open{display:block;border-top:1px solid rgba(0,0,0,0.1)}.sub-menu .fa .fa-angle-down{color:#000}@media only screen and (max-width: 1140px){#cssmenu .nav li{padding-left:0px}#cssmenu .nav li a{font-size:14px !important}}@media only screen and (max-width: 1024px){.height-wrapper{min-height:35px}.wrapper_top{position:fixed;top:0;z-index:1000;width:100%}#cssmenu .navbar-toggle{display:block}#cssmenu .nav li:hover>.sub-menu{display:none}#cssmenu .nav{z-index:1002;position:absolute;background:#20282b;display:none;top:46px;width:100%}#cssmenu .nav li:hover{border-left:0px;border-right:0px}#cssmenu .nav .sub-menu{position:static;background:none;width:100%}#cssmenu .nav .sub-menu li{border-bottom:0px;padding-left:5px;box-sizing:border-box}#cssmenu .nav .sub-menu li:last-child{border-bottom:0px}#cssmenu .nav .sub-menu li:hover{background:none;boder:0px}#cssmenu .nav .level0{width:100%;border-bottom:1px solid #4d4d4d;padding-left:0px;position:relative;box-sizing:border-box}#cssmenu .nav .level0:after{position:absolute;content:"\f105";font-family:FontAwesome;-webkit-transition:0.7s ease-in-out all;transition:0.7s ease-in-out all;right:2px;top:0px;font-size:18px;color:#000;z-index:100;padding:0px 24px;border-left:1px solid #464444;cursor:pointer}#cssmenu .nav .level0:hover{background:var(--main-color)}#cssmenu .nav .level0:hover:after{border-left:0px;transform:rotate(90deg) translate(0, 0);-webkit-transform:rotate(90deg) translate(0, 0)}#cssmenu .nav .level0 a{color:white;margin-left:10px}.sub-menu li ul li a{margin-left:20px}#cssmenu #menu-button{font-weight:700;color:#000;padding:12px;text-transform:uppercase;letter-spacing:1px;cursor:pointer;text-align:center;position:absolute;top:19px;left:10px;color:var(--black-color);border:1px solid #ccc;border-radius:6px;display:block}.toggle{display:block !important}.toggleRotate{border-left:0px;transform:rotate(90deg) translate(0, 0);-webkit-transform:rotate(90deg) translate(0, 0)}}@media screen and (max-width: 860px){#cssmenu{margin-top:-20px}}.menu_item_1291{display:none}@media screen and (max-width: 1024px){.menu_item_1291{display:block}}
