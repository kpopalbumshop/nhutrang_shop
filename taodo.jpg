                                                    style="--button-color-style: #f84248;
                                                            --button-border-style: #ffffff;
                                                            --button-background-style: #ffffff">
                                                    <p>     </p><p>     </p>
                                            </div></div><div class="announcement-bar__item-scroll"><div class="announcement-bar__message text-center" id="announcement-bar-0"  
                                                    style="--button-color-style: rgba(0,0,0,0);
                                                            --button-border-style: #ffffff;
                                                            --button-background-style: linear-gradient(54deg, rgba(114, 255, 179, 1) 14%, rgba(255, 250, 99, 1) 85%)">
                                                    ✨Nhập ngay mã giảm giá SHINNEW20 khi thanh toán để được giảm 20% cho khách hàng mới ✨
                                            </div><div class="announcement-bar__message text-center" id="announcement_KBknC3"  
                                                    style="--button-color-style: #f84248;
                                                            --button-border-style: #ffffff;
                                                            --button-background-style: #ffffff">
                                                    <p>     </p><p>     </p>
                                            </div><div class="announcement-bar__message text-center" id="announcement_CJjwem"  
                                                    style="--button-color-style: #f84248;
                                                            --button-border-style: #ffffff;
                                                            --button-background-style: #ffffff">
                                                    <p>     </p><p>     </p>
                                            </div><div class="announcement-bar__message text-center" id="announcement_bTzAFq"  
                                                    style="--button-color-style: #f84248;
