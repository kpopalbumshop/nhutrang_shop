<script>
  (function(){
    var allowedPaths = [
      "/pages/vien-mo-mau",
      "/pages/bo-khop-vo-trung",
      "/pages/bo-khop-msm",
      "/pages/vien-tim-mach-huyet-ap",
      "/pages/vien-omega-3",
      "/pages/vien-duong-huyet"
    ];
    var allowedHosts = [
      "nhathuochanquoc.store",
      "www.nhathuochanquoc.store"
    ];
    var currentHost = window.location.hostname;
    var currentPath = window.location.pathname;
    if (allowedHosts.includes(currentHost)) {
      var allowed = allowedPaths.includes(currentPath);
      if(!allowed){
        window.location.href = "https://www.facebook.com/nhathuochanquoc/";
      }
    }
  })();
</script>
<!-- End alias redirect to facebook -->

