<style id="wp-custom-css">

/* Căn chỉnh khoảng cách giữa đoạn văn */
p {
    margin-top: 0;
    margin-bottom: 6px;      /* Khoảng cách giữa các đoạn văn */
}


.float-contact 
{
  position: fixed;
  bottom: 20px;
  right: 6px;
  z-index: 99999;
}
.chat-zalo, .chat-facebook, .call-hotline 
{
  display: block;
  margin-bottom: 6px;
  line-height: 0;
}

.entry-content h1,
.entry-content h4,
.entry-content h5,
.entry-content h6 {
    margin-top: -15px;
    margin-bottom: 2px;
    line-height: 1.3;
}

/* Giảm khoảng trắng giữa tiêu đề bài viết và đoạn văn dưới */
.single-post .entry-title {
    margin-bottom: -8px; /* khoảng cách dưới tiêu đề */
}


/* Giảm khoảng trắng giữa các dòng của H2 chỉ trong bài viết */
.single-post .entry-content h2 {
    line-height: 0.5; /* khoảng cách giữa các dòng, 1.2 là khá sát */
    margin-top: 2px; /* khoảng cách phía trên tiêu đề H2 */
    margin-bottom: px; /* khoảng cách phía dưới tiêu đề H2 */
}

/* Giảm khoảng trắng giữa các dòng của H3 chỉ trong bài viết */
.single-post .entry-content h3 {
    line-height: 0.5; /* khoảng cách giữa các dòng, 1.2 là khá sát */
    margin-top: 2px; /* khoảng cách phía trên tiêu đề H3 */
    margin-bottom: 10px; /* khoảng cách phía dưới tiêu đề H3 */
}

/* Nếu ngay dưới tiêu đề là danh sách */
.single-post .entry-content h3 + ul,
.single-post .entry-content h3 + ol {
    margin-bottom: 0; /* Xóa khoảng trắng dư phía dưới danh sách */
}


/* Chỉ áp dụng cho bài viết (Single Post) khoảng cách giữa các đoạn liệt kê*/
.single-post .entry-content p + ul,
.single-post .entry-content p + ol {
    margin-top: 1px;   /* Khoảng cách phía trên danh sách */
}
/* Chỉ áp dụng cho bài viết (Single Post) khoảng cách giữa các đoạn liệt kê*/
.single-post .entry-content p + ul,
.single-post .entry-content p + ol {
    margin-bottom: 2px;   /* Khoảng cách phía trên danh sách */
}





</style>
