<section class="section" id="recent-view-coll">
	<div class="container card py-2">
		<div class="title_module section heading-bar d-flex justify-content-between align-items-center">
			<h2 class="bf_flower heading-bar__title">
				Sản phẩm đã xem
			</h2>
