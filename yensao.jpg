		<script>
			$(window).on('scroll', function (event) {
				var ww = $(window).innerWidth();
				if(ww > 991){


					var scrollValue = $(window).scrollTop();
					if (scrollValue > 141) {
						$('.subheader').addClass('affix');
					} else{
						$('.subheader').removeClass('affix');
					}
				}
			});
		</script>
