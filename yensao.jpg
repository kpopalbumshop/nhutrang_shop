		<link rel="preload" as='style' type="text/css" href="//bizweb.dktcdn.net/100/443/082/themes/847851/assets/recentview.css?1781506226726">

<link rel="stylesheet" href="//bizweb.dktcdn.net/100/443/082/themes/847851/assets/recentview.css?1781506226726">

<div class="recent-view-list row">

</div>

<script>
	function getRecentView(query){
		try{
		let storage = JSON.parse(localStorage.getItem('recentProduct')) || []
		if(storage && storage.length && Array.isArray(storage)){
			
			storage = storage.filter(item => item !== 'yen-sao-linnest-fucoidan-jp-bo-sung-duong-chat-tang-cuong-suc-khoe')
						let filter = storage.join(' OR ')
			$.ajax({
				url: `/search?q=alias:${filter}&view=recent`,
				success: function(data){
					if(data && data.length){
						let wrapper = $(query).find('.recent-view-list');
						wrapper.html(data)
						if(window.BPR && window.BPR.loadBadges){
							window.BPR.initDomEls(), window.BPR.loadBadges()
						}
						window.matchMedia('(min-width: 768px)').matches && wrapper.find('.item_product_main').length >= 5 && $(`${query} .recent-view-list`).slick({
							autoplay: false,
							autoplaySpeed: 6000,
							dots: false,
							arrows: true,
							infinite: false,
							speed: 300,
							slidesToShow: 5,
							slidesToScroll: 5,
							centerMode: false,
							responsive: [
								{
							
									breakpoint: 991,
									settings: {
										slidesToShow: 4,
										slidesToScroll: 1
									}
								},
								{
									breakpoint: 767,
									settings: {
										slidesToShow: 2,
										slidesToScroll: 2
									}
								}
							]
						});

					}else{
						$(query).remove()
					}
				}
			})

		}else{
		$(query).remove()
		}
		}catch(e){
			console.log(e)
					$(query).remove()
		}
	}
$(document).ready(()=>{
		getRecentView('#recent-view-coll')
	})
</script>
	</div>
</section>


<script> 
	var ww = $(window).width();
	if (ww <= 767) {
		$(".product_getcontent table").wrap( "<div class='table-responsive'></div>" );
	}
	var getLimit = 3;
	var productDetail = {"id":41805361,"name":"Yến Sào Linnest Fucoidan JP bổ sung dưỡng chất, tăng cường sức khỏe","alias":"yen-sao-linnest-fucoidan-jp-bo-sung-duong-chat-tang-cuong-suc-khoe","vendor":"HATAPHAR HEALTHCARE","type":"Yến Sào","content":"<h2><span style=\"font-size:18px;\"><span style=\"color:#076c37;\"><strong>Thành phần</strong></span></span></h2>\n<p><strong><em>Mỗi hũ 70ml có chứa:</em></strong></p>\n<table border=\"1\" cellpadding=\"1\" cellspacing=\"1\">\n<tbody>\n<tr>\n\t<td style=\"text-align: center;\"><strong>Thành phần</strong></td>\n\t<td style=\"text-align: center;\"><strong>Hàm lượng</strong></td>\n</tr>\n<tr>\n\t<td>Yến sào Khánh Hòa</td>\n\t<td style=\"text-align: right;\">33%</td>\n</tr>\n<tr>\n\t<td>Đông trùng hạ thảo</td>\n\t<td style=\"text-align: right;\">3%</td>\n</tr>\n<tr>\n\t<td>Đường Isomalt</td>\n\t<td style=\"text-align: right;\">3%</td>\n</tr>\n<tr>\n\t<td>Taurin&nbsp;</td>\n\t<td style=\"text-align: right;\">137mg</td>\n</tr>\n<tr>\n\t<td>Lysine</td>\n\t<td style=\"text-align: right;\">50mg</td>\n</tr>\n<tr>\n\t<td>Fucoidan</td>\n\t<td style=\"text-align: right;\">20mg</td>\n</tr>\n<tr>\n\t<td colspan=\"2\">Phụ liệu:&nbsp;Chất ổn định INS (401, 406, 412, 415, 466), chất bảo quản INS (202, 211), hương liệu tổng hợp dùng trong thực phẩm, nước vừa đủ 70ml.</td>\n</tr>\n</tbody></table>\n<h2><span style=\"font-size:18px;\"><span style=\"color:#076c37;\"><strong>Công dụng</strong></span></span></h2>\n<p><strong>Yến sào Linnest Fucoidan JP&nbsp;</strong>chứa nhiều dưỡng chất thiết yếu (Lysine, Taurine) kết hợp với Fucoidan (Nhập khẩu từ Nhật Bản) và đông trùng hạ thảo giúp bổ sung nguồn dưỡng chất thiết yếu, tăng cường sức khỏe cho mọi người mỗi ngày. Dùng được cho người ăn kiêng, người bị tiểu đường.</p>\n<h2><span style=\"color:#076c37;\"><span style=\"font-size:18px;\"><strong>Cách dùng - Liều dùng</strong></span></span></h2>\n<h3><span style=\"color:#076c37;\"><span style=\"font-size:16px;\"><strong>Cách dùng</strong></span></span></h3>\n<ul>\n<li>Sử dụng trực tiếp. Ngon hơn khi ăn để lạnh.</li>\n<li>Nên ăn ngay khi mở nắp.</li></ul>\n<h3><span style=\"font-size:16px;\"><span style=\"color:#076c37;\"><strong>Liều dùng</strong></span></span></h3>\n<ul>\n<li>Người lớn:&nbsp;Dùng 1-2 lọ/ngày,&nbsp;tùy theo thể trạng cơ thể, có thể dùng nhiều hơn.</li></ul>\n<h2><span style=\"font-size:18px;\"><span style=\"color:#076c37;\"><strong>Đối tượng sử dụng</strong></span></span></h2>\n<p>Yến Sào Linnest Fucoidan JP dùng cho người lớn, người ăn kiêng, người hay ốm vặt có sức đề kháng kém có nhu cầu bổ sung vi chất dinh dưỡng, dưỡng chất thiết yếu mỗi ngày.</p>\n<h3><span style=\"font-size:16px;\"><span style=\"color:#076c37;\"><strong>Lưu ý khi sử dụng</strong></span></span></h3>\n<ul>\n<li>Không sử dụng sản phẩm đã hết hạn.</li>\n<li>Sản phẩm này không phải là thuốc và không có tác dụng thay thế thuốc chữa bệnh.</li>\n<li>Không sử dụng cho người mẫn cảm với bất kỳ thành phần nào của sản phẩm.</li>\n<li>Không sử dụng nếu nắp bị bung, méo do va đập và sản phẩm có dấu hiệu&nbsp;chuyển màu hay có dấu hiệu bất thường.</li>\n<li>Đậy kín nắp và bảo quản trong ngăn mát tủ lạnh nếu chưa dùng hết (lưu ý không để quá 24h sau mở nắp).</li></ul>\n<h2><span style=\"font-size:18px;\"><span style=\"color:#076c37;\"><strong>Quy cách</strong></span></span></h2>\n<p>Hộp 1 lọ 70ml.</p>\n<p>Hộp 6 lọ x 70ml.</p>\n<h3><span style=\"font-size:16px;\"><span style=\"color:#076c37;\"><strong>Bảo quản</strong></span></span></h3>\n<p>Bảo quản lạnh hoặc nơi thoáng mát, tránh ánh nắng trực tiếp.<br />\nSử dụng trong 24 giờ sau khi mở nắp.</p>\n<h3><span style=\"font-size:16px;\"><span style=\"color:#076c37;\"><strong>Hạn dùng</strong></span></span></h3>\n<p>24 tháng kể từ ngày sản xuất. Ngày sản xuất và hạn sử dụng được in trên bao bì.</p>\n<h2><span style=\"font-size:18px;\"><span style=\"color:#076c37;\"><strong>Thông tin thêm</strong></span></span></h2>\n<p><strong>Chịu trách nhiệm về sản phẩm:</strong>&nbsp;Công ty Cổ phần DT Food<br />\n<strong>Địa chỉ:</strong>&nbsp;KCN Đắc Lộc, xã Vĩnh Phương, TP. Nha Trang, tỉnh Khánh Hòa, VIệt Nam.<br />\n<strong>Nhà phân phối độc quyền: </strong>Công ty Cổ phần Dược phẩm công nghệ cao Hataphar Healthcare Việt Nam.<br />\n<strong>Địa chỉ:</strong>&nbsp;Số 80 Quang Trung, Phường Quang Trung, Quận Hà Đông, TP. Hà Nội, Việt Nam.<br />\n<strong>Số TCCS: </strong>TCCS 67:2024/DTFOOD.</p>","summary":"<p><strong>Yến sào Linnest Fucoidan JP&nbsp;</strong>chứa nhiều dưỡng chất thiết yếu (Lysine, Taurine) kết hợp với Fucoidan (Nhập khẩu từ Nhật Bản) và đông trùng hạ thảo giúp bổ sung nguồn dưỡng chất thiết yếu, tăng cường sức khỏe cho mọi người mỗi ngày. Dùng được cho người ăn kiêng, người bị tiểu đường.</p>","template_layout":"product","available":true,"tags":["nước yến","tăng cường sức khỏe","thực phẩm - đồ uống","gắn khung"],"price":60000.0000,"price_min":60000.0000,"price_max":330000.0000,"price_varies":true,"compare_at_price":0,"compare_at_price_min":0,"compare_at_price_max":0,"compare_at_price_varies":false,"variants":[{"id":138539580,"barcode":"P9D0612","sku":"P9D0612","unit":null,"title":"Hộp 1 hũ","options":["Hộp 1 hũ"],"option1":"Hộp 1 hũ","option2":null,"option3":null,"available":true,"taxable":false,"price":60000.0000,"price_original":60000.0000,"compare_at_price":null,"compare_at_price_original":null,"inventory_management":null,"inventory_policy":"deny","inventory_quantity":0,"weight_unit":"g","weight":0,"requires_shipping":true,"image":{"src":"https://bizweb.dktcdn.net/100/443/082/products/yen-sao-linnest-fucoidan-jp-48.jpg?v=1741320764180"}},{"id":138539581,"barcode":"P9D061201","sku":"P9D061201","unit":null,"title":"hộp 6 hũ","options":["hộp 6 hũ"],"option1":"hộp 6 hũ","option2":null,"option3":null,"available":true,"taxable":false,"price":330000.0000,"price_original":330000.0000,"compare_at_price":null,"compare_at_price_original":null,"inventory_management":null,"inventory_policy":"deny","inventory_quantity":0,"weight_unit":"g","weight":0,"re